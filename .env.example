# Copy to .env.local and fill in. Never commit real values.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Payments — set ONE gateway (Stripe wins if both are set)
# Stripe TEST mode (Developers → API keys / Webhooks)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Razorpay TEST mode (Account & Settings → API Keys / Webhooks)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Tavily web search (agent tool)
TAVILY_API_KEY=

# 32-byte base64 secret for AES-256-GCM encryption of user LLM keys.
# Generate: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
API_KEY_ENCRYPTION_SECRET=

# Canonical site URL (prod domain), used for payment redirect URLs
NEXT_PUBLIC_SITE_URL=https://micromanus-pi.vercel.app
